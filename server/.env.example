# Server
PORT=3001
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doubleulink
DB_USER=doubleulink_user
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=https://yourdomain.com

# File Upload
UPLOAD_DIR=/var/www/doubleulink/uploads
MAX_FILE_SIZE=5242880
